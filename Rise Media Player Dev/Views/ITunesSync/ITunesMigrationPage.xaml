<Page
    x:Class="Rise.App.Views.ITunesMigrationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Matches Rise's existing CardStyles.xaml token -->
        <Style x:Key="MigrationCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}" />
            <Setter Property="Padding" Value="16,14" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar region — same padding as SongsPage, AlbumsPage -->
        <TextBlock
            Margin="56,52,56,0"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="Migrar desde iTunes" />

        <ScrollViewer Grid.Row="1" Padding="56,24,56,56">
            <StackPanel Spacing="12">

                <!-- Step indicator -->
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="0,0,0,8">
                    <TextBlock
                        x:Name="StepIndicator"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Text="Paso 1 de 4" />
                    <TextBlock
                        x:Name="StepTitle"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Localizar biblioteca de iTunes" />
                </StackPanel>

                <!-- ── STEP 1: Locate library ─────────────────────────────── -->
                <StackPanel x:Name="Step1Panel" Spacing="8">
                    <Border Style="{StaticResource MigrationCardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xEA69;" FontSize="20"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="Archivo de biblioteca" />
                                <TextBlock
                                    x:Name="LibraryPathText"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="No detectada automáticamente"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Button
                                Grid.Column="2"
                                Content="Examinar…"
                                Click="OnBrowseLibraryClick" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource MigrationCardStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="¿Qué deseas importar?" />
                            <ToggleSwitch
                                x:Name="ImportPlayCountsToggle"
                                Header="Reproducciones y skips"
                                IsOn="True" />
                            <ToggleSwitch
                                x:Name="ImportRatingsToggle"
                                Header="Valoraciones (iTunes 0–100 → Rise 0–5 ★)"
                                IsOn="True" />
                            <ToggleSwitch
                                x:Name="ImportPlaylistsToggle"
                                Header="Playlists"
                                IsOn="True" />
                            <ToggleSwitch
                                x:Name="AddLibraryFolderToggle"
                                Header="Añadir carpeta de iTunes Media a la biblioteca de Rise"
                                IsOn="True" />
                        </StackPanel>
                    </Border>

                    <Button
                        x:Name="PreviewButton"
                        HorizontalAlignment="Right"
                        Style="{StaticResource AccentButtonStyle}"
                        Content="Previsualizar →"
                        IsEnabled="False"
                        Click="OnPreviewClick" />
                </StackPanel>

                <!-- ── STEP 2: Preview ───────────────────────────────────── -->
                <StackPanel x:Name="Step2Panel" Spacing="8" Visibility="Collapsed">

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource MigrationCardStyle}">
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="TotalTracksText"
                                    Style="{StaticResource SubtitleTextBlockStyle}" Text="–" />
                                <TextBlock Text="Canciones" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource MigrationCardStyle}">
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="PlayCountsText"
                                    Style="{StaticResource SubtitleTextBlockStyle}" Text="–" />
                                <TextBlock Text="Con reproducciones" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource MigrationCardStyle}">
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="RatingsText"
                                    Style="{StaticResource SubtitleTextBlockStyle}" Text="–" />
                                <TextBlock Text="Con valoración" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Style="{StaticResource MigrationCardStyle}">
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="PlaylistsText"
                                    Style="{StaticResource SubtitleTextBlockStyle}" Text="–" />
                                <TextBlock Text="Playlists" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border x:Name="LibraryFolderCard" Style="{StaticResource MigrationCardStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE8B7;" FontSize="20"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="Carpeta de música detectada" />
                                <TextBlock x:Name="LibraryFolderText"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Content="← Atrás" Click="OnBackToStep1Click" />
                        <Button
                            Style="{StaticResource AccentButtonStyle}"
                            Content="Iniciar migración →"
                            Click="OnStartMigrationClick" />
                    </StackPanel>
                </StackPanel>

                <!-- ── STEP 3: Progress ──────────────────────────────────── -->
                <StackPanel x:Name="Step3Panel" Spacing="12" Visibility="Collapsed">
                    <Border Style="{StaticResource MigrationCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                x:Name="ProgressPhaseText"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="Iniciando…" />
                            <ProgressBar
                                x:Name="MigrationProgressBar"
                                Minimum="0" Maximum="100" Value="0" />
                            <TextBlock
                                x:Name="ProgressDetailText"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text=" " />
                        </StackPanel>
                    </Border>

                    <Button
                        x:Name="CancelMigrationButton"
                        HorizontalAlignment="Right"
                        Content="Cancelar"
                        Click="OnCancelMigrationClick" />
                </StackPanel>

                <!-- ── STEP 4: Summary ───────────────────────────────────── -->
                <StackPanel x:Name="Step4Panel" Spacing="8" Visibility="Collapsed">

                    <Border Style="{StaticResource MigrationCardStyle}">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    x:Name="ResultIcon"
                                    Glyph="&#xE73E;"
                                    FontSize="20"
                                    Foreground="#107C10" />
                                <TextBlock
                                    x:Name="ResultTitle"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="Migración completada" />
                            </StackPanel>

                            <Grid ColumnSpacing="32" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock x:Name="ResultMatchedText"
                                        Style="{StaticResource SubtitleTextBlockStyle}" Text="–" />
                                    <TextBlock Text="Coincidencias"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock x:Name="ResultRatingsText"
                                        Style="{StaticResource SubtitleTextBlockStyle}" Text="–" />
                                    <TextBlock Text="Valoraciones"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock x:Name="ResultPlayCountsText"
                                        Style="{StaticResource SubtitleTextBlockStyle}" Text="–" />
                                    <TextBlock Text="Reproducciones"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="2">
                                    <TextBlock x:Name="ResultPlaylistsText"
                                        Style="{StaticResource SubtitleTextBlockStyle}" Text="–" />
                                    <TextBlock Text="Playlists"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="UnmatchedWarning" Style="{StaticResource MigrationCardStyle}" Visibility="Collapsed">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE7BA;" FontSize="20"
                                      Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="Canciones no encontradas" />
                                <TextBlock x:Name="UnmatchedText"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Button
                        HorizontalAlignment="Right"
                        Style="{StaticResource AccentButtonStyle}"
                        Content="Ir a mi biblioteca"
                        Click="OnGoToLibraryClick" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
